# Supabase browser client (required in Vercel Project Settings > Environment Variables)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Supabase Edge Function secrets (set with `supabase secrets set`, not in Vercel)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# AI provider examples:
# supabase secrets set OPENAI_API_KEY=sk-...
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-...

# ExerciseDB / AscendAPI import script secrets.
# These are server-side only. Do not prefix RapidAPI or service-role keys with VITE_.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# RAPIDAPI_KEY=your-rapidapi-key
# RAPIDAPI_HOST=edb-with-videos-and-images-by-ascendapi.p.rapidapi.com
# EXERCISEDB_BASE_URL=https://edb-with-videos-and-images-by-ascendapi.p.rapidapi.com
# Optional if RapidAPI shows a different exact Bench Press endpoint:
# EXERCISEDB_BENCH_PRESS_URL=https://edb-with-videos-and-images-by-ascendapi.p.rapidapi.com/exercises/name/bench%20press
